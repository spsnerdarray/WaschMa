        <Single Name="ParentGuid" Type="System.Guid">b682e557-ec19-4512-8d4a-aa7118ea381d</Single>
        <Single Name="Name" Type="string">PLC_PRG</Single>
        <Dictionary Type="{2c41fa04-1834-41c1-816e-303c7aa2c05b}" Name="Properties" />
        <Single Name="TypeGuid" Type="System.Guid">6f9dac99-8de1-4efc-8465-68ac443b7d08</Single>
        <Array Name="EmbeddedTypeGuids" Type="System.Guid">
          <Single Type="System.Guid">a9ed5b7e-75c5-4651-af16-d2c27e98cb94</Single>
          <Single Type="System.Guid">3b83b776-fb25-43b8-99f2-3c507c9143fc</Single>
        </Array>
        <Single Name="Timestamp" Type="long">639117046435212365</Single>
      </Single>
      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">
IF S0_NotHalt THEN

	IF S11_WasserstandHigh THEN
		iStatusMaschine := 99;
	END_IF

 
	CASE iStatusMaschine OF
		0: (* Ausgeschaltet *)
		IF bPower THEN
			iStatusMaschine := 1;
		END_IF
	
		
		1: (* Programmauswahl *)
			fbProgrammWahl(
				bSchalter1:= S1_ProgrammWahl_1, 
				bSchalter2:= S1_ProgrammWahl_2, 
				bSchalter3:= S1_ProgrammWahl_3);
				
			IF S2_Start THEN
				iStatusMaschine := 3;
			END_IF
		
		
		3: (* Starten *)
			IF S3_DeckelGechlossen THEN
				iStatusMaschine := 4;
			END_IF	
		
		
		4: (* Wasser einlassen *)
			IF W1_Waage &gt;= fbProgrammWahl.iWasserMenge THEN
				V1_Wasser := FALSE;
				iStatusMaschine := 5;
			ELSE
				V1_Wasser := TRUE;
			END_IF
			
		
		5: (* Wasser heizen *)
			IF T1_WasserTemperatur &gt;= fbProgrammWahl.iTemperatur THEN
				K1_Heizung := FALSE;
				iStatusMaschine := 6;
			ELSE
				K1_Heizung := TRUE;
			END_IF


		6: (* Waschmittel dosieren *)
			IF W1_Waage &gt;= fbProgrammWahl.iWaschmittelMenge THEN
				V2_Waschmittel := FALSE;
				iStatusMaschine := 7;
			ELSE
			V2_Waschmittel := TRUE;
			END_IF
		

		7: (* Waschen*)
			IF iRichtungsWechselAnzahl &gt;= fbProgrammWahl.iRichtungsWechselAnzahl THEN

				iStatusMaschine := 8;
			ELSE
				;
			END_IF

		
		8: (* Wasser ablassen *)
			IF W1_Waage &lt;= 10 AND S10_WasserstandLow THEN
				iStatusMaschine := 9;
			ELSE
				M2_Abwasser := TRUE;
				V4_Abwasser := TRUE;
			END_IF

		9: (* Schleudern *)
			IF iSchleuderZeit &gt;= fbProgrammWahl.iSchleuderZeit THEN
				M2_Abwasser := FALSE;
				V4_Abwasser := FALSE;
				iStatusMaschine := 0;
			ELSE
				M2_Abwasser := TRUE;
				V4_Abwasser := TRUE;
			END_IF


		99: (* Fehler *)
		;
		
	ELSE	
		
		;
		
	END_CASE

 
 
 
 
 
 
 
 
 
 






ELSE
	 
 	V1_Wasser        := FALSE;
	V2_Waschmittel   := FALSE;
	V3_Weichspueler  := FALSE;
	V4_Abwasser 	 := FALSE;
	K1_Heizung 		 := FALSE;
	M2_Abwasser 	 := FALSE;
	U1_Freigabe    	 := FALSE;
	U1_Start         := FALSE;
	U1_SollDrehzahl  := 0;
	
 END_IF</Single>
            <Single Name="LineInfoPersistence" Type="string">39b162e0-be70-4714-9607-c0cae74c7331_Impl_LineIds</Single>
          </Single>
