            <Single Name="TextBlobForSerialisation" Type="string">
iProgramm.0 := bSchalter1;
iProgramm.1 := bSchalter2;
iProgramm.2 := bSchalter3;


</Single>
            <Single Name="LineInfoPersistence" Type="string">c1b546ae-bd4e-4351-906e-13562c18d348_Impl_LineIds</Single>
