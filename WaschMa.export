            <Single Name="TextBlobForSerialisation" Type="string">PROGRAM PLC_PRG
VAR

	iStatusMaschine : INT;
	fbProgrammWahl : FB_ProgrammWahl;
	iRichtungsWechselAnzahl : INT;
	iSchleuderZeit : INT;
	bPower : BOOL;
	
END_VAR</Single>
