        <Single Name="Interface" Type="{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">FUNCTION_BLOCK FB_ProgrammWahl
VAR_INPUT
	bSchalter1 : BOOL;
	bSchalter2 : BOOL;
	bSchalter3 : BOOL;
END_VAR
VAR_OUTPUT
	bWeichspueler : BOOL;
	iTemperatur	: INT;
	iWasserMenge : INT;
	iWaschmittelMenge : INT;
	iSchleuderDrehzahl : INT;
	iSchleuderZeit : INT;
	iRichtungsWechselAnzahl : INT; 
END_VAR
VAR
		iProgramm : INT;
END_VAR
</Single>
